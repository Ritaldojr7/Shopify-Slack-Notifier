# Supabase Session pooler connection string (port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Shopify webhook signing secret (Settings > Notifications > Webhooks)
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# Slack bot token with chat:write scope
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack channel ID to post notifications to
SLACK_CHANNEL_ID=C0123456789

# Your Shopify store subdomain (e.g. "my-store" for my-store.myshopify.com)
SHOP=your-store

# Shopify Admin API access token (for one-off backfill: npm run backfill)
SHOPIFY_ADMIN_TOKEN=shpat_your_admin_api_token

# Port the Express server listens on
PORT=3000
